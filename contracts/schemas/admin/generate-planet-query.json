{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://infinity/contracts/schemas/admin/generate-planet-query.json",
  "title": "GeneratePlanetQuery",
  "description": "Query parameters for GET /infinity/admin/planets/generate.",
  "x-infinity-source": "infinity/src/modules/admin/dto/generate-planet-query.dto.ts",
  "x-infinity-usage": "query",
  "type": "object",
  "properties": {
    "seed": {
      "type": "string",
      "description": "Deterministic generation seed. A random UUID is used when omitted."
    },
    "radius": {
      "type": "integer",
      "minimum": 5,
      "maximum": 15,
      "default": 10
    },
    "type": {
      "type": "string",
      "enum": ["rocky", "ice", "lava"],
      "default": "rocky"
    }
  },
  "additionalProperties": false
}
