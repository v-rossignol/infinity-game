{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://infinity/contracts/schemas/auth/auth-user.json",
  "title": "AuthUser",
  "description": "Public user shape returned by auth endpoints and GET /infinity/auth/me.",
  "x-infinity-source": "infinity/src/modules/auth/dto/auth-user.dto.ts",
  "x-infinity-usage": "response",
  "type": "object",
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "username": { "type": "string" },
    "email": { "type": "string", "format": "email" }
  },
  "required": ["id", "username", "email"],
  "additionalProperties": false
}
