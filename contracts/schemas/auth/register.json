{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://infinity/contracts/schemas/auth/register.json",
  "title": "RegisterDto",
  "description": "Account creation payload for POST /infinity/auth/register.",
  "x-infinity-source": "infinity/src/modules/auth/dto/register.dto.ts",
  "x-infinity-usage": "body",
  "type": "object",
  "properties": {
    "username": { "type": "string", "minLength": 1 },
    "password": { "type": "string", "minLength": 6 },
    "email": { "type": "string", "format": "email" }
  },
  "required": ["username", "password"],
  "additionalProperties": false
}
