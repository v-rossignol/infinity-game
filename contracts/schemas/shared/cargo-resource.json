{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://infinity/contracts/schemas/shared/cargo-resource.json",
  "title": "CargoResource",
  "description": "A single resource entry with id and quantity. Mirrors @infinity/shared-types CargoResource.",
  "x-infinity-source": "packages/shared-types/src/Cargo.ts#CargoResource",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "description": "Terrain resource id (e.g. wood, stone)."
    },
    "quantity": {
      "type": "number",
      "minimum": 1,
      "description": "Quantity to transfer."
    }
  },
  "required": ["id", "quantity"],
  "additionalProperties": false
}
