{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://infinity/contracts/schemas/responses/unit-type.json",
  "title": "UnitType",
  "description": "Unit type catalog definition embedded in unit instance responses.",
  "x-infinity-source": "packages/shared-types/src/Unit.ts#UnitTypeDefinition",
  "type": "object",
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "type": { "type": "string", "enum": ["vehicule", "building"] },
    "size": { "type": "string", "enum": ["small", "medium", "large"] },
    "mobility": { "type": "boolean" },
    "speed": {
      "type": ["number", "null"],
      "description": "Rate multiplier for movement. 1 = one hex per 2 min at planet-surface depth (null = immobile)."
    },
    "environments": {
      "type": "array",
      "items": {
        "type": "string",
        "description": "Atomic biome id (e.g. forest) or compound side-zone pair (e.g. ocean+plain)."
      },
      "description": "Allowed build environments. Atomic entries require matching biomes on every hex involved; compound entries require a side zone between exactly those two biomes."
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "range": { "type": "string", "enum": ["hexagon"] },
          "value": { "type": "number" }
        },
        "required": ["range", "value"],
        "additionalProperties": false
      }
    },
    "capabilities": { "$ref": "unit-capabilities.json" },
    "description": { "type": ["string", "null"] },
    "metadata": { "type": "object" },
    "recipe": { "$ref": "unit-recipe.json" }
  },
  "required": [
    "id",
    "name",
    "type",
    "size",
    "mobility",
    "speed",
    "environments",
    "rules",
    "capabilities",
    "description",
    "metadata"
  ],
  "additionalProperties": false
}
