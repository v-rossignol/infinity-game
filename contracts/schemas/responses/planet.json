{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://infinity/contracts/schemas/responses/planet.json",
  "title": "Planet",
  "description": "Planet surface MongoDB document.",
  "x-infinity-source": "infinity/src/modules/planets/entities/planet.schema.ts",
  "type": "object",
  "properties": {
    "_id": { "type": "string" },
    "name": { "type": "string" },
    "starSystemId": { "type": "string", "format": "uuid" },
    "type": {
      "type": "string",
      "enum": ["rocky", "gas", "ice", "lava"]
    },
    "radius": { "type": "integer", "minimum": 5, "maximum": 15 },
    "resources": {
      "type": "object",
      "additionalProperties": { "type": "number" }
    },
    "surface": {
      "type": "object",
      "properties": {
        "hexagons": {
          "type": "array",
          "items": { "$ref": "planet-hexagon.json" }
        },
        "generatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["hexagons", "generatedAt"],
      "additionalProperties": false
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  },
  "required": [
    "_id",
    "name",
    "starSystemId",
    "type",
    "radius",
    "resources",
    "surface",
    "createdAt",
    "updatedAt"
  ],
  "additionalProperties": false
}
