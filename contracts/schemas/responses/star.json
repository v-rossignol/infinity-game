{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://infinity/contracts/schemas/responses/star.json",
  "title": "Star",
  "description": "Star within a galaxy cube.",
  "x-infinity-source": "infinity/src/shared/interfaces/galaxy.interface.ts#StarData",
  "type": "object",
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "name": { "type": "string" },
    "local_coords": { "$ref": "vec3.json" },
    "cube_id": { "type": "string", "format": "uuid" },
    "properties": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["yellow", "red", "blue", "white"]
        }
      },
      "required": ["type"],
      "additionalProperties": false
    }
  },
  "required": ["id", "name", "local_coords", "cube_id", "properties"],
  "additionalProperties": false
}
