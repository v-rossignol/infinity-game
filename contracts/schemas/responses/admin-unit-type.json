{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://infinity/contracts/schemas/responses/admin-unit-type.json",
  "title": "AdminUnitType",
  "description": "Unit type catalog entry for admin listing.",
  "x-infinity-source": "infinity/src/modules/admin/admin.service.ts#AdminUnitTypeSummary",
  "type": "object",
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "type": { "type": "string", "enum": ["vehicule", "building"] },
    "size": { "type": "string", "enum": ["small", "medium", "large"] },
    "mobility": { "type": "boolean" },
    "speed": { "type": ["number", "null"] },
    "environments": {
      "type": "array",
      "items": { "type": "string" }
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "range": { "type": "string", "enum": ["hexagon"] },
          "value": { "type": "number" }
        },
        "required": ["range", "value"],
        "additionalProperties": false
      }
    },
    "capabilities": { "type": "object" },
    "description": { "type": ["string", "null"] },
    "metadata": { "type": "object" },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  },
  "required": [
    "id",
    "name",
    "type",
    "size",
    "mobility",
    "speed",
    "environments",
    "rules",
    "capabilities",
    "description",
    "metadata",
    "createdAt",
    "updatedAt"
  ],
  "additionalProperties": false
}
