{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://infinity/contracts/schemas/responses/player.json",
  "title": "Player",
  "description": "Player profile stored in PostgreSQL.",
  "x-infinity-source": "infinity/src/modules/players/entities/player.entity.ts",
  "type": "object",
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "userId": { "type": "string", "format": "uuid" },
    "location": {
      "oneOf": [
        { "$ref": "../shared/player-location.json" },
        { "type": "null" }
      ]
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  },
  "required": ["id", "userId", "location", "createdAt", "updatedAt"],
  "additionalProperties": false
}
