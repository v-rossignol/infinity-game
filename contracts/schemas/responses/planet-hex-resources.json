{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://infinity/contracts/schemas/responses/planet-hex-resources.json",
  "title": "PlanetHexResources",
  "description": "Resources available on a single planet hex cell.",
  "x-infinity-source": "infinity/src/modules/resources/resources.service.ts#PlanetHexResourcesResponse",
  "type": "object",
  "properties": {
    "planetId": { "type": "string" },
    "coordinates": { "$ref": "../shared/hex-coords.json" },
    "biome": {
      "type": "string",
      "enum": ["desert", "forest", "ocean", "mountain", "ice", "volcanic", "plain"]
    },
    "resources": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": { "type": "string" },
          "abundance": { "type": "number" },
          "rarity": {
            "type": "string",
            "enum": ["common", "rare", "epic", "legendary"]
          }
        },
        "required": ["type", "abundance", "rarity"],
        "additionalProperties": false
      }
    }
  },
  "required": ["planetId", "coordinates", "biome", "resources"],
  "additionalProperties": false
}
