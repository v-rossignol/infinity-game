{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://infinity/contracts/schemas/responses/planet-hexagon.json",
  "title": "PlanetHexagon",
  "description": "Single hex cell on a planet surface.",
  "x-infinity-source": "infinity/src/shared/interfaces/planet.interface.ts#Hexagon",
  "type": "object",
  "properties": {
    "biome": {
      "type": "string",
      "enum": ["desert", "forest", "ocean", "mountain", "ice", "volcanic", "plain"]
    },
    "resources": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": { "type": "string" },
          "abundance": { "type": "number" },
          "rarity": {
            "type": "string",
            "enum": ["common", "rare", "epic", "legendary"]
          }
        },
        "required": ["type", "abundance", "rarity"],
        "additionalProperties": false
      }
    },
    "dangerLevel": { "type": "integer", "minimum": 0, "maximum": 10 },
    "coordinates": { "$ref": "../shared/hex-coords.json" }
  },
  "required": ["biome", "resources", "dangerLevel", "coordinates"],
  "additionalProperties": false
}
